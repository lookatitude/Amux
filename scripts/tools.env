# Amux build-time tool pins — single source of truth (T3 devops, ADR-0007).
#
# Sourced by the Makefile and every CI workflow so the toolchain never floats
# with the host. These are BUILD-TIME tools: per ADR-0007 Decision 3 they are
# NEVER added to go.mod (they would create unevidenced module-graph edges).
# Bumping any pin here is a deliberate change: update, re-run `make verify`, and
# record the reason in the commit — same mechanics as a dependency bump.
#
# Values are plain KEY=VALUE (no spaces) so both `sh` and GitHub Actions
# `source` / `>> $GITHUB_ENV` can consume the file unchanged.

# Go toolchain — must match the `toolchain` directive in go.mod. `GOTOOLCHAIN`
# is exported so `go` refuses to silently download a different toolchain.
GO_VERSION=1.26.5
GOTOOLCHAIN=go1.26.5

# Static analyser beyond `go vet`. Date-versioned releases.
STATICCHECK_VERSION=2025.1.1

# Release tooling (ADR-0007 Decision 1: GoReleaser is selected, pinned by T3).
# Pinned to a v2 release that parses the checked-in config as authored. The
# config's floor is GoReleaser >= 2.8: `archives[].formats` landed in v2.6 but
# `archives[].ids` only landed in v2.8, and GoReleaser decodes strictly, so
# v2.6/v2.7 hard-fail on `ids`. Config and pin are kept coherent together.
#
# Bumped v2.5.1 -> v2.12.7 to close review finding F3 ("frozen release pipeline
# cannot build with the pinned GoReleaser configuration"): v2.5.1 rejects
# `ids`/`formats`. What this pin is evidenced to do, on real Linux, against the
# checked-in config with NO ad-hoc edits (run it yourself:
# `scripts/release/linux-release-gates.sh arm64 <evidence-dir>`):
#   make release-check                     exit=0
#   make release-snapshot                  exit=0  (linux amd64 + arm64 tarballs,
#                                                   checksums.txt, per-archive
#                                                   CycloneDX SBOMs)
#   scripts/release/record-provenance.sh   exit=0
#   make release-verify                    exit=0
# Evidence: .amux-artifacts/devops-t6/release-frozen-20260722/release-gates-arm64.log
#
# The installed-CLI smoke (packaging/smoke/smoke-install.sh) also passes against
# these exact tarballs, run in a clean ubuntu:24.04 container with no Go
# toolchain, on BOTH arches: `smoke: PASS`, SMOKE_INSTALL_EXIT=0, with
# `amux --version` printing the stamped identity. Reproduce with
# `scripts/release/linux-install-smoke.sh <evidence-dir>`.
# Evidence: .amux-artifacts/devops-t6/release-frozen-20260722/install-smoke.log
#
# What this pin is still NOT evidenced to do: hosted CI. Every log above comes
# from local containers on one darwin host; the ubuntu-24.04 GitHub runner lane
# is unrun, and reproducibility is measured same-host/different-user only, never
# cross-machine. Do not read this pin as "the release is green" — it means the
# release path BUILDS, its artifacts verify, and they install and run on Linux.
GORELEASER_VERSION=v2.12.7

# SBOM generator invoked by the release pipeline.
SYFT_VERSION=v1.18.1

# CGO is prohibited for every build in this repo (ADR-0007 Decision 4).
CGO_ENABLED=0
