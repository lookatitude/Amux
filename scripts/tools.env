# Amux build-time tool pins — single source of truth (T3 devops, ADR-0007).
#
# Sourced by the Makefile and every CI workflow so the toolchain never floats
# with the host. These are BUILD-TIME tools: per ADR-0007 Decision 3 they are
# NEVER added to go.mod (they would create unevidenced module-graph edges).
# Bumping any pin here is a deliberate change: update, re-run `make verify`, and
# record the reason in the commit — same mechanics as a dependency bump.
#
# Values are plain KEY=VALUE (no spaces) so both `sh` and GitHub Actions
# `source` / `>> $GITHUB_ENV` can consume the file unchanged.

# Go toolchain — must match the `toolchain` directive in go.mod. `GOTOOLCHAIN`
# is exported so `go` refuses to silently download a different toolchain.
GO_VERSION=1.26.5
GOTOOLCHAIN=go1.26.5

# Static analyser beyond `go vet`. Date-versioned releases.
STATICCHECK_VERSION=2025.1.1

# Release tooling (ADR-0007 Decision 1: GoReleaser is selected, pinned by T3).
# Pinned to a v2 release that parses the checked-in config as authored: the
# archive `ids`/`formats` keys require GoReleaser >= 2.6, so the config and this
# pin are kept coherent together. v2.12.7 is the validated pin (release-check +
# snapshot + artifact verify + install smoke all green for linux amd64/arm64).
GORELEASER_VERSION=v2.12.7

# SBOM generator invoked by the release pipeline.
SYFT_VERSION=v1.18.1

# CGO is prohibited for every build in this repo (ADR-0007 Decision 4).
CGO_ENABLED=0
